<?xml version="1.0" encoding="utf-8"?>
<!--
  Civil 3D auto-load bundle. Modeled on ADSK-ProjectExplorer-2026.bundle.
  Series (internal release codes, not calendar year):
    Civil 3D 2021 = R24.0, 2022 = R24.1, 2023 = R24.2, 2024 = R24.3
    Civil 3D 2025 = R25.0, 2026 = R25.1
  No R24.3 ComponentEntry: Civil 3D 2024 runs .NET Framework 4.8 (net48 plugins).
  Contents/*.dll are net8.0-windows (2025+ only). A net48 build + separate DLL path
  is required before adding SeriesMin/Max R24.3 — see README "Civil 3D 2024 compatibility".
-->
<ApplicationPackage SchemaVersion="1.0"
                    AppVersion="1.1.0"
                    Name="HydroComplete for Civil 3D"
                    Description="Stormwater analysis driven straight from your Civil 3D drawing — Rational, SCS Tc, Manning, IDF with full formula transparency."
                    ProductCode="{8d07b4c8-06cb-497d-832a-dcb5b095d9fa}"
                    HelpFile="https://hydrocomplete.com/civil3d"
                    Icon="./Contents/PackageIcon.png">

  <CompanyDetails Name="HydroComplete"
                  Url="https://hydrocomplete.com/civil3d"
                  Email="support@hydrocomplete.com" />

  <Components>
    <!-- Civil 3D 2025 (R25.0) — same net8.0-windows DLLs as 2026 -->
    <RuntimeRequirements OS="Win64" Platform="Civil3D" SeriesMin="R25.0" SeriesMax="R25.0" />
    <ComponentEntry AppName="HYDROCOMPLETE"
                    AppDescription="HydroComplete stormwater analysis"
                    AppType=".NET"
