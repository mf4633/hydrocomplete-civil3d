<?xml version="1.0" encoding="utf-8"?>
<!--
  AutoCAD/Civil 3D auto-load bundle manifest. Drop the whole "HydroComplete.bundle"
  folder into one of AutoCAD's ApplicationPlugins locations and the plugin loads
  automatically on startup — no NETLOAD needed:
    %APPDATA%\Autodesk\ApplicationPlugins\          (per user)
    %ProgramFiles%\Autodesk\ApplicationPlugins\     (all users)
  This is also the package format the Autodesk App Store distributes.

  Series mapping: AutoCAD/Civil 3D 2025 = R25.0, 2026 = R25.1.
-->
<ApplicationPackage SchemaVersion="1.0"
                    AppVersion="0.1.0"
                    ProductCode="{8d07b4c8-06cb-497d-832a-dcb5b095d9fa}"
                    Name="HydroComplete for Civil 3D"
                    Description="Stormwater analysis driven straight from your Civil 3D drawing — Rational, SCS Tc, Manning, IDF with full formula transparency.">

  <CompanyDetails Name="HydroComplete"
                  Url="https://hydrocomplete.com/civil3d"
                  Email="support@hydrocomplete.com" />

  <Components Description="Civil 3D 2025 / 2026 (.NET 8)">
    <!-- Civil3D platform is required; AutoCAD* alone may not match Civil 3D hosts. -->
    <RuntimeRequirements OS="Win64" Platform="Civil3D" SeriesMin="R25.0" SeriesMax="R25.1" />
    <ComponentEntry AppName="HydroComplete.Civil3D"
                    ModuleName="./Contents/HydroComplete.Civil3D.dll"
                    AppType="NET"
                    LoadOnAutoCADStartup="True"
                    LoadReasonOnCommandInvocation="True"
                    PerDocument="False">
      <Commands GroupName="HYDROCOMPLETE">
        <Command Global="HC_ABOUT" Local="HC_ABOUT" />
        <Command Global="HC_PIPES" Local="HC_PIPES" />
        <Command Global="HC_PIPES_WRITE" Local="HC_PIPES_WRITE" />
        <Command Global="HC_RATIONAL" Local="HC_RATIONAL" />
      </Commands>
    </ComponentEntry>
  </Components>

</ApplicationPackage>
